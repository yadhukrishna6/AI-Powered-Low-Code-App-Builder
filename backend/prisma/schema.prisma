generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id             String     @id @default(uuid())
  name           String
  description    String?
  thumbnailColor String?
  status         String     @default("Draft")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  forms          Form[]
  workflows      Workflow[]

  @@map("projects")
}

model Form {
  id          String       @id @default(uuid())
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id])
  name        String
  schema      Json
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  submissions Submission[]

  @@map("forms")
}

model Submission {
  id        String   @id @default(uuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id])
  data      Json
  createdAt DateTime @default(now())

  @@map("submissions")
}

model Workflow {
  id          String      @id @default(uuid())
  projectId   String?
  project     Project?    @relation(fields: [projectId], references: [id])
  name        String
  description String?
  draftGraph  Json?       // The current working draft
  status      String      @default("draft") // draft, active, archived
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  versions    WorkflowVersion[]
  activeVersionId String?
  executions  WorkflowExecution[]

  @@map("workflows")
}

model WorkflowVersion {
  id          String    @id @default(uuid())
  workflowId  String
  workflow    Workflow  @relation(fields: [workflowId], references: [id])
  version     Int
  graph       Json      // { nodes: Node[], edges: Edge[] }
  metadata    Json?     // Version specific notes, author, etc.
  createdAt   DateTime  @default(now())
  
  executions  WorkflowExecution[]
  scheduledJobs ScheduledJob[]
  
  @@unique([workflowId, version])
  @@map("workflow_versions")
}

model WorkflowExecution {
  id            String    @id @default(uuid())
  workflowId    String
  workflow      Workflow  @relation(fields: [workflowId], references: [id])
  versionId     String?
  version       WorkflowVersion? @relation(fields: [versionId], references: [id])
  status        String    @default("queued") // queued, running, waiting, success, failed, cancelled
  triggerSource String?   // webhook, form, schedule, manual
  context       Json      // Variables and data passed through the flow
  result        Json?     // Final output
  startTime     DateTime  @default(now())
  endTime       DateTime?
  logs          WorkflowLog[]

  // New execution state tracking
  nodeStates    ExecutionNodeState[]
  edgeStates    ExecutionEdgeState[]
  approvalTasks ApprovalTask[]
  snapshots     ReplaySnapshot[]

  @@map("workflow_executions")
}

model WorkflowLog {
  id            String    @id @default(uuid())
  executionId   String
  execution     WorkflowExecution @relation(fields: [executionId], references: [id])
  nodeId        String
  nodeType      String
  status        String    // running, success, error, skipped
  input         Json?
  output        Json?
  error         String?
  timestamp     DateTime  @default(now())

  @@map("workflow_logs")
}

model ExecutionNodeState {
  id            String   @id @default(uuid())
  executionId   String
  execution     WorkflowExecution @relation(fields: [executionId], references: [id])
  nodeId        String
  state         String   // idle, queued, running, success, failed, skipped, waiting, cancelled
  startedAt     DateTime?
  completedAt   DateTime?
  duration      Int?     // milliseconds
  error         String?
  retryCount    Int      @default(0)
  output        Json?
  input         Json?
  branchTaken   String?

  @@unique([executionId, nodeId])
  @@map("execution_node_states")
}

model ExecutionEdgeState {
  id             String   @id @default(uuid())
  executionId    String
  execution      WorkflowExecution @relation(fields: [executionId], references: [id])
  edgeId         String
  state          String   // inactive, active, success-path, failed-path, skipped-path
  executedAt     DateTime?
  executionCount Int      @default(0)
  branchType     String?

  @@unique([executionId, edgeId])
  @@map("execution_edge_states")
}

model ApprovalTask {
  id            String    @id @default(uuid())
  executionId   String
  execution     WorkflowExecution @relation(fields: [executionId], references: [id])
  nodeId        String
  approverRole  String?
  approverId    String?
  status        String    @default("pending") // pending, approved, rejected, expired
  timeoutAt     DateTime?
  remindedAt    DateTime?
  actionedAt    DateTime?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("approval_tasks")
}

model ScheduledJob {
  id            String    @id @default(uuid())
  workflowId    String
  versionId     String
  version       WorkflowVersion @relation(fields: [versionId], references: [id])
  cron          String?
  runAt         DateTime?
  payload       Json?
  status        String    @default("active") // active, completed, failed, cancelled
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("scheduled_jobs")
}

model ReplaySnapshot {
  id            String    @id @default(uuid())
  executionId   String
  execution     WorkflowExecution @relation(fields: [executionId], references: [id])
  nodeId        String
  context       Json      // Full variables state at this point
  timestamp     DateTime  @default(now())

  @@map("replay_snapshots")
}

model BusinessRule {
  id            String   @id @default(uuid())
  targetField   String
  triggerFields Json
  formula       String?
  validation    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("business_rules")
}

